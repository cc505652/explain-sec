rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // MIGRATION NOTE: These rules were simplified to support direct Firestore operations
    // after reverting from Cloud Functions. Future migration back to Cloud Functions
    // should restore the more granular role-based access controls.

    match /issues/{id} {
      allow read: if request.auth != null
        && (
          resource.data.escalatedTo == "soc_l2"
          || resource.data.assignedTo == "soc_l2"
          || resource.data.createdBy == request.auth.uid
          || resource.data.assignedTo == request.auth.uid
          || resource.data.assignedTo == "IR Team"
        );
      allow update: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /audit_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Evidence subcollection for incidents
    match /issues/{issueId}/evidence/{evidenceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // FALLBACK: deny all unmatched collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
